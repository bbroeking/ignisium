# Copy this to .env and fill in your values. .env is gitignored.

# Your Discord USER token (NOT a bot token). Required to drive the MJ slash
# command via discord.py-self. WARNING: this token authorizes full access to
# your Discord account — never share it, never commit it, never paste it into
# anything you don't trust.
#
# How to extract:
#   1. Open https://discord.com/app in a Chromium-based browser
#   2. F12 -> Network tab -> filter "/api"
#   3. Click any channel to fire a request
#   4. Pick a request -> Headers -> Request Headers -> "authorization"
#   5. Copy the value (long opaque string starting with letters/digits)
#
# Note: refreshing the page or logging out invalidates the token.
DISCORD_TOKEN=

# The Discord channel ID where the Midjourney bot lives in your server.
# Right-click the channel -> Copy Channel ID (you must have Developer Mode
# enabled in Discord settings -> Advanced).
DISCORD_CHANNEL_ID=

# Optional: local Ollama model to use for richer prompt generation.
# Leave blank to use the templated fallback (works fine, just less varied).
# Suggested: pull a small fast model like `ollama pull qwen2.5:3b` or
# `ollama pull llama3.2:3b` and put its name here.
OLLAMA_MODEL=

# Optional: Ollama HTTP base URL. Default is http://localhost:11434.
OLLAMA_HOST=http://localhost:11434
